{
  "name": "Space Explorer - Training",
  "description": "Treine um chatbot com dados de intenções e conhecimento",
  "steps": [
    {
      "name": "Carregar Intenções de Treinamento",
      "type": "ingestion",
      "enabled": true,
      "config": {
        "ingestion_type": "file_upload",
        "file_format": "csv",
        "file_path": "C:\\dev\\flowscope\\data\\use_cases\\space_chatbot_intent_training.csv",
        "description": "CSV com colunas: text, intent (exemplo: \"Olá, tudo bem?\" -> \"greeting\")"
