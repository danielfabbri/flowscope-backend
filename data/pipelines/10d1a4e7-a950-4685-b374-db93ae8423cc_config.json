        "file_path": "C:\\dev\\flowscope\\data\\use_cases\\space_chatbot_knowledge_base.csv",
        "description": "CSV com colunas: text (perguntas e respostas, documentos, FAQs)"
      }
    },
    {
      "name": "Indexar Conhecimento",
      "type": "knowledge_indexing",
      "enabled": true,
      "config": {
        "text_column": "text",
        "id_column": "id",
        "metadata_columns": [],
        "index_name": "space_explorer_kb"
      }
    }
  ],
