{
    "id": "nlp_sentiment_classifier",
    "name": "NLP: Product Review Sentiment Classifier",
    "description": "Pipeline completa de NLP para classificar sentimentos de reviews (Positive/Negative/Neutral). Demonstra todos os steps: normalização, tokenização, stop words, lemmatização, vetorização TF-IDF e treinamento.",
    "created_at": "2026-06-12T00:00:00",
    "steps": [
        {
            "id": "step_1",
            "name": "Load Product Reviews",
            "type": "ingestion",
            "config": {
                "ingestion_type": "file_upload",
                "file_format": "csv",
                "file_path": "data/use_cases/nlp/product_reviews_train.csv"
            }
        },
        {
            "id": "step_2",
            "name": "Profile Data",
            "type": "profiling",
            "config": {
                "generate_report": true
            }
        },
        {
            "id": "step_3",
            "name": "Select Relevant Columns",
            "type": "column_selection",
            "config": {
                "columns_to_keep": "review_text,rating,verified_purchase,helpful_votes,sentiment"
            }
        },
        {
            "id": "step_4",
            "name": "Normalize Text",
            "type": "text_normalization",
            "config": {
                "text_columns": "review_text",
                "lowercase": true,
                "remove_html": true,
                "remove_urls": true,
                "remove_emails": true,
                "remove_punctuation": false,
                "remove_numbers": false,
                "normalize_whitespace": true,
                "output_suffix": "_normalized",
                "inplace": false
            }
        },
        {
            "id": "step_5",
            "name": "Tokenize Text",
            "type": "tokenization",
            "config": {
                "text_columns": "review_text_normalized",
                "method": "word",
                "min_token_length": 2,
                "max_token_length": 50,
                "keep_case": false,
                "output_suffix": "_tokens",
                "output_as_string": false
            }
        },
        {
            "id": "step_6",
            "name": "Remove Stop Words",
            "type": "stopwords_removal",
            "config": {
                "text_columns": "review_text_normalized_tokens",
                "language": "english",
                "custom_stopwords": [],
                "case_sensitive": false,
                "input_format": "list",
                "output_format": "list",
                "output_suffix": "_filtered"
            }
        },
        {
            "id": "step_7",
            "name": "Lemmatize Tokens",
            "type": "stemming_lemmatization",
            "config": {
                "text_columns": "review_text_normalized_tokens_filtered",
                "method": "lemmatize",
                "language": "english",
                "pos_tagging": false,
                "input_format": "list",
                "output_format": "list",
                "output_suffix": "_lemmatized"
            }
        },
        {
            "id": "step_8",
            "name": "TF-IDF Vectorization",
            "type": "text_vectorization",
            "config": {
                "text_columns": "review_text_normalized_tokens_filtered_lemmatized",
                "method": "tfidf",
                "max_features": 200,
                "min_df": 2,
                "max_df": 0.9,
                "ngram_range": [
                    1,
                    2
                ],
                "use_idf": true,
                "sublinear_tf": true,
                "norm": "l2",
                "input_format": "tokens",
                "output_format": "columns",
                "feature_prefix": "tfidf",
                "top_n_features": null
            }
        },
        {
            "id": "step_9",
            "name": "Sentiment Features",
            "type": "sentiment_analysis",
            "config": {
                "text_columns": "review_text_normalized",
                "metrics": [
                    "polarity",
                    "subjectivity"
                ],
                "polarity_threshold": 0.1,
                "input_format": "text",
                "token_separator": " ",
                "suffix_polarity": "_polarity",
                "suffix_subjectivity": "_subjectivity"
            }
        },
        {
            "id": "step_10",
            "name": "Scale Numeric Features",
            "type": "feature_engineering",
            "config": {
                "transformation_type": "scaling",
                "scaling_columns": "rating,helpful_votes",
                "scaling_method": "standard"
            }
        },
        {
            "id": "step_11",
            "name": "Train Sentiment Classifier",
            "type": "ml_model_training",
            "config": {
                "model_name": "product_review_sentiment_classifier",
                "problem_type": "classification",
                "target_column": "sentiment",
                "algorithm": "random_forest",
                "test_size": 0.2,
                "random_state": 42,
                "n_estimators": 200,
                "max_depth": 20,
                "min_samples_split": 5,
                "min_samples_leaf": 2,
                "class_weight": "balanced",
                "feature_columns": []
            }
        },
        {
            "id": "step_12",
            "name": "Save Results",
            "type": "output",
            "config": {
                "include_metadata": true
            }
        }
    ]
}