{
    "name": "Space Explorer - Conversação",
    "description": "Pipeline para conversar com o chatbot espacial treinado",
    "version": "1.0",
    "category": "chatbot",
    "steps": [
        {
            "name": "Pergunta do Usuário",
            "type": "user_input",
            "config": {
                "user_question": "",
                "prompt_on_run": "Faça sua pergunta sobre o espaço:",
                "use_defaults": false
            }
        },
        {
            "name": "Classificar Intenção",
            "type": "intent_classification",
            "config": {
                "model_name": "space_explorer",
                "text_column": "user_question",
                "min_confidence": 0.4,
                "output_intent_column": "predicted_intent",
                "output_confidence_column": "intent_confidence"
            }
        },
        {
            "name": "Buscar Conhecimento",
            "type": "semantic_search",
            "config": {
                "kb_name": "space_explorer_kb",
                "query_column": "user_question",
                "top_k": 3,
                "min_similarity": 0.3,
                "output_column": "search_results"
            }
        },
        {
            "name": "Gerar Resposta",
            "type": "response_generation",
            "config": {
                "intent_column": "predicted_intent",
                "context_column": "search_results",
                "query_column": "user_question",
                "response_style": "friendly_educational",
                "output_column": "response"
            }
        }
    ]
}